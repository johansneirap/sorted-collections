{
  "name": "sorted-collections",
  "version": "1.0.3",
  "description": "SortedList, SortedSet and SortedMap for JavaScript/TypeScript — zero runtime dependencies, inspired by Python's sortedcontainers.",
  "keywords": [
    "sorted",
    "sorted-list",
    "sorted-set",
    "sorted-map",
    "data-structures",
    "sortedcontainers",
    "typescript"
  ],
  "homepage": "https://johansneirap.github.io/sorted-collections/",
  "bugs": {
    "url": "https://github.com/johansneirap/sorted-collections/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johansneirap/sorted-collections.git"
  },
  "license": "MIT",
  "author": "Johans Neira",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx benchmarks/run.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "docs:api": "typedoc",
    "docs:dev": "npm run docs:api && vitepress dev docs-site",
    "docs:build": "npm run docs:api && vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "publint": "publint",
    "attw": "attw --pack .",
    "size": "size-limit",
    "prepublishOnly": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run publint && npm run attw && npm run size"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB"
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.9.0",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "sorted-containers": "^0.4.0",
    "sortedkit": "^0.1.0",
    "tinybench": "^6.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "vue": "^3.5.39"
  },
  "packageManager": "npm@11.8.0"
}
